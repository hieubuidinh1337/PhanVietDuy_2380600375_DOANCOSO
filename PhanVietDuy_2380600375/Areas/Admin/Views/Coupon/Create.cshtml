@using PhanVietDuy_2380600375.Models.ViewModels
@model CouponCreateViewModel
@{
  ViewData["Title"] = "Thêm mã giảm giá mới";
  Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
  ViewData["Breadcrumb"] = "<a href='/admin/coupon'>Mã giảm giá</a> <span>/</span> <span>Thêm mới</span>";
}

<div class="card reveal" style="max-width:800px">
  <div class="card__header">
    <h2 class="card__title">Thông tin mã giảm giá</h2>
  </div>
  <div class="card__body">
    <form asp-action="Create" method="post" id="couponForm">
      @Html.AntiForgeryToken()

      <div class="form-grid">
        <div class="form__group">
          <label asp-for="Code" class="form__label">Mã giảm giá (Code) <span class="text-danger">*</span></label>
          <input asp-for="Code" class="form__input" style="text-transform:uppercase" placeholder="Ví dụ: SUMMER20" required />
          <span asp-validation-for="Code" class="form__error"></span>
        </div>

        <div class="form__group">
          <label asp-for="DiscountType" class="form__label">Loại giảm giá <span class="text-danger">*</span></label>
          <select asp-for="DiscountType" class="form__select" required>
            <option value="Percentage">Phần trăm (%)</option>
            <option value="FixedAmount">Số tiền cố định ($)</option>
          </select>
          <span asp-validation-for="DiscountType" class="form__error"></span>
        </div>

        <div class="form__group">
          <label asp-for="DiscountValue" class="form__label">Giá trị giảm <span class="text-danger">*</span></label>
          <input asp-for="DiscountValue" type="number" step="0.01" min="0.01" class="form__input" placeholder="Ví dụ: 10, 50..." required />
          <span asp-validation-for="DiscountValue" class="form__error"></span>
        </div>

        <div class="form__group">
          <label asp-for="MinOrderAmount" class="form__label">Giá trị đơn hàng tối thiểu</label>
          <input asp-for="MinOrderAmount" type="number" step="0.01" min="0" class="form__input" placeholder="Ví dụ: 500 (Bỏ trống nếu không yêu cầu)" />
          <span asp-validation-for="MinOrderAmount" class="form__error"></span>
        </div>

        <div class="form__group">
          <label asp-for="ExpiresAt" class="form__label">Ngày hết hạn</label>
          <input asp-for="ExpiresAt" type="date" class="form__input" />
          <span asp-validation-for="ExpiresAt" class="form__error"></span>
        </div>

        <div class="form__group">
          <label class="form__label" style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-top:var(--sp-6)">
            <input asp-for="IsActive" type="checkbox" style="width:18px;height:18px;accent-color:var(--c-gold)" />
            Kích hoạt ngay
          </label>
        </div>

        <div class="form__group" style="grid-column: 1 / -1">
          <label asp-for="Description" class="form__label">Mô tả thêm</label>
          <textarea asp-for="Description" class="form__textarea" rows="3" placeholder="Ghi chú về mã giảm giá..."></textarea>
          <span asp-validation-for="Description" class="form__error"></span>
        </div>
      </div>

      <div style="margin-top:var(--sp-6);display:flex;gap:var(--sp-4);justify-content:flex-end;border-top:1px solid var(--c-border);padding-top:var(--sp-6)">
        <a href="/admin/coupon" class="btn btn--outline">Hủy bỏ</a>
        <button type="submit" class="btn btn--gold">Lưu mã giảm giá</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
