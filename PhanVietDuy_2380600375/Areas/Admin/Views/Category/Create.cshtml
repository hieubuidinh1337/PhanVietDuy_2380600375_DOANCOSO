@using PhanVietDuy_2380600375.Models.ViewModels
@model CategoryCreateViewModel
@{
  ViewData["Title"] = "Thêm danh mục mới";
  Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section Styles {
  <style>
    .media-upload-zone {
      position: relative;
      border: 1px dashed var(--c-gold);
      border-radius: var(--r-sm);
      padding: 32px;
      text-align: center;
      background: var(--c-bg-alt);
      transition: all var(--dur-base) var(--ease-out);
      cursor: pointer;
      overflow: hidden;
      margin-top: 8px;
    }
    .media-upload-zone:hover {
      background: rgba(184,150,62,0.03);
    }
    .media-upload-input {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
      z-index: 2;
    }
    .media-upload-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--sp-2);
    }
    .media-upload-icon {
      font-size: 1.8rem;
      color: var(--c-gold);
      margin-bottom: 4px;
    }
    .media-upload-text {
      font-size: var(--fs-xs);
      letter-spacing: 0.05em;
      font-weight: 400;
      color: var(--c-ink);
    }
    .media-upload-sub {
      font-size: 10px;
      color: var(--c-ink-lt);
    }
    .media-upload-preview {
      position: relative;
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 3;
    }
    .media-upload-preview img {
      max-height: 160px;
      max-width: 100%;
      object-fit: contain;
      border-radius: var(--r-sm);
      border: 1px solid var(--c-border);
    }
    .media-upload-remove {
      position: absolute;
      top: -8px;
      right: -8px;
      background: var(--c-surface);
      border: 1px solid var(--c-border);
      border-radius: 50%;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--c-danger);
      cursor: pointer;
      transition: all var(--dur-fast);
      box-shadow: var(--sh-sm);
    }
    .media-upload-remove:hover {
      background: var(--c-danger);
      color: #fff;
      border-color: var(--c-danger);
    }
  </style>
}

<div class="admin-card reveal" style="max-width:600px;margin:0 auto">
  <div class="admin-card__header">
    <h2 class="admin-card__title">Thông tin danh mục mới</h2>
  </div>
  <div class="admin-card__body">
    <form method="post" enctype="multipart/form-data" class="form-stack">
      <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

      <div class="form__group">
        <label asp-for="Name" class="form__label">Tên danh mục <span style="color:var(--c-gold)">*</span></label>
        <input asp-for="Name" class="form__input" placeholder="Ví dụ: Đồng hồ hiệu" />
        <span asp-validation-for="Name" class="form__error"></span>
      </div>

      <div class="form__group">
        <label asp-for="Label" class="form__label">Nhãn hiển thị</label>
        <input asp-for="Label" class="form__input" placeholder="Ví dụ: Watches" />
        <span asp-validation-for="Label" class="form__error"></span>
      </div>

      <div class="form__group">
        <label asp-for="Description" class="form__label">Mô tả ngắn</label>
        <textarea asp-for="Description" class="form__textarea" rows="3" placeholder="Mô tả cho danh mục này..."></textarea>
        <span asp-validation-for="Description" class="form__error"></span>
      </div>

      <div class="form__group">
        <label asp-for="ImageFile" class="form__label">Hình ảnh danh mục</label>
        <div class="media-upload-zone" id="uploadZone">
          <input asp-for="ImageFile" type="file" class="media-upload-input" accept="image/*" onchange="previewImage(this)" />
          <div class="media-upload-placeholder" id="uploadPlaceholder">
            <i class="fa-regular fa-cloud-arrow-up media-upload-icon" aria-hidden="true"></i>
            <span class="media-upload-text">Chọn tệp hình ảnh danh mục</span>
            <span class="media-upload-sub">Hỗ trợ JPG, PNG, WEBP (Tối đa 5MB)</span>
          </div>
          <div class="media-upload-preview" id="uploadPreview" style="display:none">
            <img id="imagePreview" src="" alt="Preview" />
            <button type="button" class="media-upload-remove" onclick="removeImage(event)"><i class="fa-regular fa-trash"></i></button>
          </div>
        </div>
        <span asp-validation-for="ImageFile" class="form__error"></span>
      </div>

      <div class="form__group">
        <label asp-for="SortOrder" class="form__label">Thứ tự hiển thị</label>
        <input asp-for="SortOrder" type="number" class="form__input" value="0" />
        <span asp-validation-for="SortOrder" class="form__error"></span>
      </div>

      <div class="form__group" style="margin-top:20px;margin-bottom:24px">
        <label class="form__checkbox">
          <input asp-for="IsActive" type="checkbox" />
          <span class="form__checkbox-label">Kích hoạt hoạt động danh mục</span>
        </label>
      </div>

      <div style="display:flex;gap:12px;margin-top:var(--sp-6)">
        <button type="submit" class="btn btn--gold">Lưu lại</button>
        <a href="/admin/danh-muc" class="btn btn--ghost">Quay lại</a>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <script>
    function previewImage(input) {
      if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
          document.getElementById('imagePreview').src = e.target.result;
          document.getElementById('uploadPlaceholder').style.display = 'none';
          document.getElementById('uploadPreview').style.display = 'flex';
        }
        reader.readAsDataURL(input.files[0]);
      }
    }

    function removeImage(e) {
      e.preventDefault();
      e.stopPropagation();
      var input = document.querySelector('.media-upload-input');
      input.value = '';
      document.getElementById('imagePreview').src = '';
      document.getElementById('uploadPlaceholder').style.display = 'flex';
      document.getElementById('uploadPreview').style.display = 'none';
    }
  </script>
}
