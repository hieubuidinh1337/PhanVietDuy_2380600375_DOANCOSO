@using PhanVietDuy_2380600375.Models.Domain
@using X.PagedList
@model IPagedList<ApplicationUser>
@{
  ViewData["Title"] = "Quản lý người dùng";
  Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@* ── Filters ── *@
<div class="admin-card reveal" style="margin-bottom:24px">
  <div class="admin-card__body">
    <form method="get" style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end">
      <div class="form-group" style="flex:1;min-width:200px;margin:0">
        <label for="search" class="form-label">Tìm kiếm người dùng</label>
        <input type="text" id="search" name="search" class="form-control" value="@ViewBag.Search" placeholder="Tên hoặc email..." />
      </div>

      <div class="form-group" style="width:200px;margin:0">
        <label for="role" class="form-label">Vai trò</label>
        <select id="role" name="role" class="form-control" asp-items="ViewBag.Roles">
          <option value="">Tất cả vai trò</option>
        </select>
      </div>

      <div class="form-group" style="width:150px;margin:0">
        <label for="isActive" class="form-label">Trạng thái</label>
        <select id="isActive" name="isActive" class="form-control">
          <option value="">Tất cả</option>
          <!option value="true" @(ViewBag.IsActive == true ? "selected" : "")>Đang hoạt động</!option>
          <!option value="false" @(ViewBag.IsActive == false ? "selected" : "")>Tạm khóa</!option>
        </select>
      </div>

      <div style="display:flex;gap:8px">
        <button type="submit" class="btn btn--gold" style="padding:10px 20px">Lọc</button>
        <a href="/admin/nguoi-dung" class="btn btn--ghost" style="padding:10px 20px">Xóa lọc</a>
      </div>
    </form>
  </div>
</div>

@* ── Table ── *@
<div class="data-table-wrap reveal">
  <div class="data-table-header">
    <h2 class="data-table-header__title">Danh sách người dùng</h2>
  </div>

  <div style="overflow-x:auto">
    <table class="data-table" aria-label="Danh sách người dùng">
      <thead>
        <tr>
          <th scope="col">Hình ảnh</th>
          <th scope="col">Họ tên & Email</th>
          <th scope="col">Số điện thoại</th>
          <th scope="col">Tuổi / Tỉnh thành</th>
          <th scope="col">Ngày đăng ký</th>
          <th scope="col" style="text-align:center">Trạng thái</th>
          <th scope="col"><span class="sr-only">Thao tác</span></th>
        </tr>
      </thead>
      <tbody>
        @if (Model != null && Model.Any())
        {
          foreach (var u in Model)
          {
            <tr id="row-@u.Id">
              <td>
                @if (!string.IsNullOrEmpty(u.AvatarUrl))
                {
                  <img src="@u.AvatarUrl" alt="@u.FullName" style="width:40px;height:40px;object-fit:cover;border-radius:var(--r-full)" />
                }
                else
                {
                  <div style="width:40px;height:40px;background:var(--c-border);display:flex;align-items:center;justify-content:center;border-radius:var(--r-full);color:var(--c-ink-lt)">
                    <i class="fa-regular fa-user" aria-hidden="true"></i>
                  </div>
                }
              </td>
              <td>
                <div style="font-weight:500;color:var(--c-ink)">@(string.IsNullOrEmpty(u.FullName) ? "Chưa cập nhật" : u.FullName)</div>
                <div style="font-size:var(--fs-xs);color:var(--c-ink-lt)">@u.Email</div>
              </td>
              <td>@(string.IsNullOrEmpty(u.PhoneNumber) ? "Chưa có" : u.PhoneNumber)</td>
              <td>
                @if (u.Age.HasValue)
                {
                  <span>@u.Age.Value tuổi</span>
                }
                @if (!string.IsNullOrEmpty(u.City))
                {
                  <span style="color:var(--c-ink-lt)"> / @u.City</span>
                }
              </td>
              <td>@(u.CreatedAt?.ToString("dd/MM/yyyy") ?? "—")</td>
              <td style="text-align:center">
                <button type="button" class="status-badge @(u.IsActive ? "status-badge--shipped" : "status-badge--cancelled")" onclick="toggleUserActive('@u.Id')" id="user-badge-@u.Id" style="border:none;cursor:pointer">
                  @(u.IsActive ? "Hoạt động" : "Tạm khóa")
                </button>
              </td>
              <td>
                <div style="display:flex;gap:8px;justify-content:flex-end">
                  <a href="/admin/nguoi-dung/detail/@u.Id" class="quick-action-btn">Chi tiết</a>
                  <a href="/admin/nguoi-dung/edit/@u.Id" class="quick-action-btn">Sửa</a>
                  <button type="button" onclick="toggleUserActive('@u.Id')" id="btn-toggle-@u.Id" class="quick-action-btn @(u.IsActive ? "quick-action-btn--warning" : "quick-action-btn--success")" style="border:none;background:none">
                    @(u.IsActive ? "Chặn" : "Bỏ chặn")
                  </button>
                  <button type="button" onclick="deleteUser('@u.Id')" class="quick-action-btn quick-action-btn--danger" style="border:none;background:none">Xóa</button>
                </div>
              </td>
            </tr>
          }
        }
        else
        {
          <tr>
            <td colspan="7" style="text-align:center;padding:var(--sp-8);color:var(--c-ink-lt)">
              Không tìm thấy người dùng nào.
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  @if (Model != null && Model.PageCount > 1)
  {
    <div style="display:flex;justify-content:center;padding:24px">
      @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model)
    </div>
  }
</div>

@section Scripts {
  <script>
    function toggleUserActive(id) {
      fetch(`/admin/nguoi-dung/ToggleActive/${id}`, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" }
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          const badge = document.getElementById(`user-badge-${id}`);
          const btn = document.getElementById(`btn-toggle-${id}`);
          if (data.isActive) {
            if (badge) {
              badge.className = "status-badge status-badge--shipped";
              badge.innerText = "Hoạt động";
            }
            if (btn) {
              btn.innerText = "Chặn";
              btn.className = "quick-action-btn quick-action-btn--warning";
            }
          } else {
            if (badge) {
              badge.className = "status-badge status-badge--cancelled";
              badge.innerText = "Tạm khóa";
            }
            if (btn) {
              btn.innerText = "Bỏ chặn";
              btn.className = "quick-action-btn quick-action-btn--success";
            }
          }
        }
      });
    }

    function deleteUser(id) {
      if (confirm("Bạn có chắc chắn muốn xóa tài khoản người dùng này? Hành động này không thể hoàn tác.")) {
        fetch(`/admin/nguoi-dung/Delete/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" }
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert(data.message || "Đã xóa người dùng thành công!");
            const row = document.getElementById(`row-${id}`);
            if (row) row.remove();
          } else {
            alert(data.message || "Xóa thất bại!");
          }
        })
        .catch(err => {
          alert("Lỗi hệ thống khi xóa!");
          console.error(err);
        });
      }
    }
  </script>
}
