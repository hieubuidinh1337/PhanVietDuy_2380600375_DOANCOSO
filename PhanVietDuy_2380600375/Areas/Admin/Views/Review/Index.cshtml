@using PhanVietDuy_2380600375.Models.Domain
@using X.PagedList
@model IPagedList<Review>
@{
  ViewData["Title"] = "Quản lý đánh giá";
  Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@* ── Filters ── *@
<div class="admin-card reveal" style="margin-bottom:24px">
  <div class="admin-card__body">
    <form method="get" style="display:flex;flex-wrap:wrap;gap:16px;align-items:flex-end">
      <div class="form-group" style="width:200px;margin:0">
        <label for="approved" class="form-label">Duyệt/Chưa duyệt</label>
        <select id="approved" name="approved" class="form-control">
          <option value="">Tất cả</option>
          <option value="true" selected="@(ViewBag.Approved == true ? "selected" : null)">Đã duyệt</option>
          <option value="false" selected="@(ViewBag.Approved == false ? "selected" : null)">Chờ duyệt</option>
        </select>
      </div>

      <div style="display:flex;gap:8px">
        <button type="submit" class="btn btn--gold" style="padding:10px 20px">Lọc</button>
        <a href="/admin/danh-gia" class="btn btn--ghost" style="padding:10px 20px">Xóa lọc</a>
      </div>
    </form>
  </div>
</div>

@* ── Table ── *@
<div class="data-table-wrap reveal">
  <div class="data-table-header">
    <h2 class="data-table-header__title">Danh sách đánh giá</h2>
  </div>

  <div style="overflow-x:auto">
    <table class="data-table" aria-label="Danh sách đánh giá">
      <thead>
        <tr>
          <th scope="col">Khách hàng</th>
          <th scope="col">Sản phẩm</th>
          <th scope="col">Đánh giá (Sao)</th>
          <th scope="col">Nội dung</th>
          <th scope="col">Ngày tạo</th>
          <th scope="col" style="text-align:center">Duyệt</th>
          <th scope="col" style="text-align:center">Trang chủ</th>
          <th scope="col"><span class="sr-only">Thao tác</span></th>
        </tr>
      </thead>
      <tbody>
        @if (Model != null && Model.Any())
        {
          foreach (var r in Model)
          {
            <tr id="row-@r.Id">
              <td>
                <div style="font-weight:500;color:var(--c-ink)">@r.AuthorName</div>
                @if (!string.IsNullOrEmpty(r.AuthorTitle))
                {
                  <div style="font-size:var(--fs-xxs);color:var(--c-ink-lt)">@r.AuthorTitle</div>
                }
              </td>
              <td>
                <span style="font-size:var(--fs-xs);color:var(--c-ink-mid)">@r.Product.Name</span>
              </td>
              <td>
                <div style="display:flex;gap:2px;color:var(--c-gold)">
                  @for (int i = 1; i <= 5; i++)
                  {
                    <i class="@(i <= r.Rating ? "fa-solid" : "fa-regular") fa-star fa-xs" aria-hidden="true"></i>
                  }
                </div>
              </td>
              <td style="max-width:300px;font-size:var(--fs-sm);line-height:1.4">
                @r.Content
              </td>
              <td style="font-size:var(--fs-xs)">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
              <td style="text-align:center" id="approved-td-@r.Id">
                @if (r.IsApproved)
                {
                  <span class="status-badge status-badge--shipped">Đã duyệt</span>
                }
                else
                {
                  <button type="button" class="status-badge status-badge--pending" onclick="approveReview(@r.Id)" style="border:none;cursor:pointer">Duyệt</button>
                }
              </td>
              <td style="text-align:center">
                <button type="button" class="btn-icon" onclick="toggleHomepageReview(@r.Id)" id="homepage-btn-@r.Id" @(!r.IsApproved ? "disabled" : "")>
                  <i class="@(r.IsHomepage ? "fa-solid fa-house" : "fa-regular fa-house")" style="color:var(--c-gold)"></i>
                </button>
              </td>
              <td>
                <div style="display:flex;gap:8px;justify-content:flex-end">
                  <button class="quick-action-btn quick-action-btn--danger" onclick="rejectReview(@r.Id)" type="button">Xóa</button>
                </div>
              </td>
            </tr>
          }
        }
        else
        {
          <tr>
            <td colspan="8" style="text-align:center;padding:var(--sp-8);color:var(--c-ink-lt)">
              Không tìm thấy đánh giá nào.
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>

  @if (Model != null && Model.PageCount > 1)
  {
    <div style="display:flex;justify-content:center;padding:24px">
      @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model)
    </div>
  }
</div>

@section Scripts {
  <script>
    function approveReview(id) {
      fetch(`/admin/danh-gia/Approve/${id}`, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" }
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          document.getElementById(`approved-td-${id}`).innerHTML = '<span class="status-badge status-badge--shipped">Đã duyệt</span>';
          document.getElementById(`homepage-btn-${id}`).removeAttribute("disabled");
        } else {
          alert("Duyệt đánh giá thất bại!");
        }
      });
    }

    function toggleHomepageReview(id) {
      fetch(`/admin/danh-gia/ToggleHomepage/${id}`, {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" }
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          const icon = document.querySelector(`#homepage-btn-${id} i`);
          if (data.isHomepage) {
            icon.className = "fa-solid fa-house";
          } else {
            icon.className = "fa-regular fa-house";
          }
        }
      });
    }

    function rejectReview(id) {
      if (confirm("Bạn có chắc chắn muốn xóa/từ chối đánh giá này?")) {
        fetch(`/admin/danh-gia/Reject/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" }
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            document.getElementById(`row-${id}`).remove();
          } else {
            alert("Không thể xóa đánh giá!");
          }
        });
      }
    }
  </script>
}
