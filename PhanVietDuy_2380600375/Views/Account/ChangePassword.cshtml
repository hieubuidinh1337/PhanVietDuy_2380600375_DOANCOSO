@using PhanVietDuy_2380600375.Models.ViewModels
@model ChangePasswordViewModel
@{
  ViewData["Title"] = "Đổi mật khẩu";
  ViewData["Page"] = "change-password";
}

<div class="container" style="max-width:var(--content-w);margin:var(--sp-8) auto;padding:0 var(--sp-4)">
  <div style="margin-bottom:var(--sp-6)">
    <span class="section-tag">Tài khoản</span>
    <h1 style="font-family:var(--ff-display);font-size:var(--fs-display-lg);font-weight:300;margin-top:var(--sp-1)">
      Đổi <em>mật khẩu</em>
    </h1>
  </div>

  @if (TempData["Success"] != null)
  {
    <div class="alert alert--success" style="background:rgba(59,109,17,0.08);border:1px solid rgba(59,109,17,0.25);border-radius:var(--r-md);padding:var(--sp-4);margin-bottom:var(--sp-5);color:var(--c-success);font-size:var(--fs-sm)">
      <i class="fa-solid fa-circle-check" style="margin-right:8px"></i> @TempData["Success"]
    </div>
  }

  <div class="profile-layout" style="display:grid;grid-template-columns:300px 1fr;gap:var(--sp-7)">
    
    @* ── LEFT SIDEBAR ── *@
    <div class="profile-sidebar" style="display:flex;flex-direction:column;gap:var(--sp-5)">
      
      @* Navigation link list *@
      <div style="background:var(--c-surface);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-4);box-shadow:var(--sh-sm);display:flex;flex-direction:column;gap:var(--sp-2)">
        <a href="/tai-khoan/ho-so" style="display:flex;align-items:center;gap:12px;padding:12px;font-size:var(--fs-sm);color:var(--c-ink-mid);text-decoration:none;border-radius:var(--r-md);transition:all var(--dur-fast)">
          <i class="fa-solid fa-user" style="width:16px"></i> Thông tin cá nhân
        </a>
        <a href="/don-hang" style="display:flex;align-items:center;gap:12px;padding:12px;font-size:var(--fs-sm);color:var(--c-ink-mid);text-decoration:none;border-radius:var(--r-md);transition:all var(--dur-fast)">
          <i class="fa-solid fa-box" style="width:16px"></i> Lịch sử đơn hàng
        </a>
        <a href="/tai-khoan/doi-mat-khau" style="display:flex;align-items:center;gap:12px;padding:12px;font-size:var(--fs-sm);color:var(--c-gold);font-weight:500;text-decoration:none;border-radius:var(--r-md);background:var(--c-bg)">
          <i class="fa-solid fa-lock" style="width:16px"></i> Đổi mật khẩu
        </a>
        <div style="height:1px;background:var(--c-border);margin:var(--sp-2) 0"></div>
        <a href="/tai-khoan/dang-xuat" style="display:flex;align-items:center;gap:12px;padding:12px;font-size:var(--fs-sm);color:var(--c-danger);text-decoration:none;border-radius:var(--r-md);transition:all var(--dur-fast)">
          <i class="fa-solid fa-arrow-right-from-bracket" style="width:16px"></i> Đăng xuất
        </a>
      </div>

    </div>

    @* ── RIGHT COLUMN ── *@
    <div>
      
      @* Password form *@
      <div style="background:var(--c-surface);border:1px solid var(--c-border);border-radius:var(--r-lg);padding:var(--sp-6);box-shadow:var(--sh-sm)">
        <h3 style="font-family:var(--ff-display);font-size:1.5rem;font-weight:300;margin-bottom:var(--sp-5)">
          Đặt <em>mật khẩu mới</em>
        </h3>

        @if (!ViewData.ModelState.IsValid)
        {
          <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        }
        
        <form method="post" action="/Account/ChangePassword" novalidate>
          @Html.AntiForgeryToken()

          <div class="form__group @(ViewData.ModelState["CurrentPassword"]?.Errors.Count > 0 ? "has-error" : "")">
            <label class="form__label" asp-for="CurrentPassword">Mật khẩu hiện tại <span aria-hidden="true">*</span></label>
            <input class="form__input" asp-for="CurrentPassword" type="password" required />
            <span class="form__error" asp-validation-for="CurrentPassword"></span>
          </div>

          <div class="form__row" style="margin-bottom:var(--sp-4)">
            <div class="form__group @(ViewData.ModelState["NewPassword"]?.Errors.Count > 0 ? "has-error" : "")">
              <label class="form__label" asp-for="NewPassword">Mật khẩu mới <span aria-hidden="true">*</span></label>
              <input class="form__input" asp-for="NewPassword" type="password" required />
              <span class="form__error" asp-validation-for="NewPassword"></span>
            </div>
            
            <div class="form__group @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "has-error" : "")">
              <label class="form__label" asp-for="ConfirmPassword">Xác nhận mật khẩu mới <span aria-hidden="true">*</span></label>
              <input class="form__input" asp-for="ConfirmPassword" type="password" required />
              <span class="form__error" asp-validation-for="ConfirmPassword"></span>
            </div>
          </div>

          <button type="submit" class="btn btn--solid btn--lg">
            Đổi mật khẩu
          </button>
        </form>
      </div>

    </div>

  </div>
</div>
