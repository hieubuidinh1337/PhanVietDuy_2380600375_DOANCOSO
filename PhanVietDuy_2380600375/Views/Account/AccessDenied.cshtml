@{
    ViewData["Title"] = "Không có quyền truy cập";
    ViewData["Page"] = "access-denied";
}

<style>
/* ════════════════════════════════════════════════════════════════
   ACCESS DENIED PAGE — Luxury Editorial Style
   ════════════════════════════════════════════════════════════════ */
.denied-page {
    min-height: calc(100vh - var(--nav-h) - 100px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--c-bg);
    padding: 80px 24px;
    position: relative;
    overflow: hidden;
}

/* ── Decorative background text ── */
.denied-page::before {
    content: 'RESTRICTED';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--ff-display);
    font-size: clamp(6rem, 18vw, 22rem);
    font-weight: 300;
    color: transparent;
    -webkit-text-stroke: 1px rgba(184,150,62,0.06);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    letter-spacing: -0.04em;
    z-index: 0;
}

.denied__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 600px;
    background: rgba(247,245,242,0.85);
    backdrop-filter: blur(12px);
    padding: 64px 40px;
    border: 1px solid var(--c-border);
    border-radius: 2px;
    box-shadow: 0 24px 64px rgba(26,24,20,0.06);
}

.denied__icon {
    font-size: 2.5rem;
    color: var(--c-danger, #A53A3A);
    margin-bottom: 24px;
    opacity: 0.8;
}

.denied__eyebrow {
    display: block;
    font-family: var(--ff-body);
    font-size: var(--fs-2xs);
    font-weight: 400;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--c-gold);
    margin-bottom: 12px;
}

.denied__title {
    font-family: var(--ff-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--c-ink);
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -0.01em;
}

.denied__title em {
    font-style: italic;
    color: var(--c-danger, #A53A3A);
}

.denied__desc {
    font-family: var(--ff-body);
    font-size: var(--fs-base);
    font-weight: 300;
    color: var(--c-ink-mid);
    line-height: 1.7;
    margin-bottom: 40px;
}

.denied__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
}

.denied-rule {
    width: 44px;
    height: 1px;
    background: var(--c-gold);
    margin: 0 auto 32px;
}
</style>

<div class="denied-page">
    <div class="denied__inner">
        <i class="fa-solid fa-lock denied__icon" aria-hidden="true"></i>
        
        <span class="denied__eyebrow">Truy cập bị từ chối</span>
        <h1 class="denied__title">Khu vực <em>hạn chế</em></h1>
        
        <div class="denied-rule"></div>
        
        <p class="denied__desc">
            Bạn không có quyền truy cập vào trang này. Khu vực này dành riêng cho quản trị viên và nhân viên của hệ thống Vietduy Atelier.
        </p>
        
        <div class="denied__actions">
            <a href="/" class="btn btn--solid">Về trang chủ</a>
            <a href="javascript:history.back()" class="btn btn--outline">Quay lại trang trước</a>
        </div>
    </div>
</div>
