@* ══════════════════════════════════════════════════════════════════════
   SCRIPTS — Intersection Observer + Cursor + Lookbook drag
   ══════════════════════════════════════════════════════════════════════ *@
<script>
(function () {
  'use strict';

  /* ── 1. Scroll reveal ─────────────────────────────────────────────── */
  const revealEls = document.querySelectorAll(
    '.reveal-fade, .reveal-clip, .reveal-up, .reveal-line, .section-header'
  );
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.12 }
  );
  revealEls.forEach(el => io.observe(el));

  /* ── 2. Featured products reveal on enter ─────────────────────────── */
  const featuredSec = document.getElementById('featuredSection');
  if (featuredSec) {
    const fpIO = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          featuredSec.classList.add('products-revealed');
          fpIO.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    fpIO.observe(featuredSec);
  }

  /* ── 3. Custom cursor ─────────────────────────────────────────────── */
  const dot  = document.getElementById('cursor-dot');
  const ring = document.getElementById('cursor-ring');
  if (dot && ring && window.matchMedia('(pointer:fine)').matches) {
    let rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      const x = e.clientX, y = e.clientY;
      dot.style.transform  = `translate(${x}px,${y}px) translate(-50%,-50%)`;
      rx += (x - rx) * .12;
      ry += (y - ry) * .12;
      ring.style.transform = `translate(${rx}px,${ry}px) translate(-50%,-50%)`;
    });
    requestAnimationFrame(function tick() {
      ring.style.transform = `translate(${rx}px,${ry}px) translate(-50%,-50%)`;
      requestAnimationFrame(tick);
    });
  }

  /* ── 4. Lookbook drag-to-scroll ──────────────────────────────────── */
  const reel = document.getElementById('lookbookReel');
  if (reel) {
    let isDown = false, startX, scrollLeft;
    reel.addEventListener('mousedown', e => {
      isDown = true;
      reel.style.cursor = 'grabbing';
      startX    = e.pageX - reel.offsetLeft;
      scrollLeft = reel.scrollLeft;
    });
    reel.addEventListener('mouseleave', () => { isDown = false; reel.style.cursor = 'grab'; });
    reel.addEventListener('mouseup',    () => { isDown = false; reel.style.cursor = 'grab'; });
    reel.addEventListener('mousemove',  e => {
      if (!isDown) return;
      e.preventDefault();
      const x    = e.pageX - reel.offsetLeft;
      const walk = (x - startX) * 1.6;
      reel.scrollLeft = scrollLeft - walk;
    });
  }

  /* ── 5. Smooth counter animation for Numbers section ─────────────── */
  const counters = document.querySelectorAll('.numbers__val');
  const cIO = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el   = entry.target;
      const text = el.textContent;
      const num  = parseFloat(text.replace(/[^0-9.]/g, ''));
      if (isNaN(num)) return;
      const suffix = text.replace(/[0-9.]/g, '');
      let start = null;
      const duration = 1600;
      const step = ts => {
        if (!start) start = ts;
        const progress = Math.min((ts - start) / duration, 1);
        const ease     = 1 - Math.pow(1 - progress, 3);
        el.textContent = (num < 100
          ? Math.round(ease * num)
          : Math.round(ease * num)) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      cIO.unobserve(el);
    });
  }, { threshold: .5 });
  counters.forEach(c => cIO.observe(c));

})();
</script>
