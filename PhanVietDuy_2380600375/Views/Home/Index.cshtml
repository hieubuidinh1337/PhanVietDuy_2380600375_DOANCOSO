@* ══════════════════════════════════════════════════════════════════════
   ACT 2 — COLLECTIONS
   ══════════════════════════════════════════════════════════════════════ *@
<section class="collections" aria-labelledby="collections-title">
  <div class="container">
    <div class="section-header reveal-fade">
      <span class="section-eyebrow">Khám phá</span>
      <h2 class="section-title" id="collections-title">Danh mục nổi bật</h2>
      <div class="reveal-rule"></div>
    </div>

    <div class="collections-grid">
      @if (Model?.Categories?.Any() == true)
      {
        int ci = 0;
        var colClasses   = new[] { "coll-card--portrait", "coll-card--square", "coll-card--medium" };
        var fallbackImgs = new[] {
          "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&q=80",
          "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=800&q=80",
          "https://images.unsplash.com/photo-1544923246-14c90c9f8935?w=800&q=80"
        };
        foreach (var cat in Model.Categories.Take(3))
        {
          var cls   = colClasses[ci % colClasses.Length];
          var delay = ci * 120;
          var img   = cat.ImageUrl ?? fallbackImgs[ci];
          ci++;
          <a href="/product?category=@cat.Slug"
             class="coll-card @cls reveal-fade"
             style="--reveal-delay: @(delay)ms"
             aria-label="Xem danh mục @cat.Label">
            <img
              src="@img"
              alt="@cat.Label"
              class="coll-card__img"
              width="800" height="@(cls == "coll-card--portrait" ? 1067 : 800)"
              loading="@(ci == 1 ? "eager" : "lazy")" />
            <div class="coll-card__overlay" aria-hidden="true"></div>
            <div class="coll-card__body">
              <span class="coll-card__tag">0@ci — Collection</span>
              <h3 class="coll-card__name">@cat.Label</h3>
              <span class="coll-card__link">
                Xem bộ sưu tập
                <i class="fa-solid fa-arrow-right fa-xs" aria-hidden="true"></i>
              </span>
            </div>
          </a>
        }
      }
      else
      {
        var fallbackCollections = new[]
        {
          new { Tag = "01 — Fine Jewelry",  Name = "Trang sức Cao cấp",   Slug = "trang-suc",   Cls = "coll-card--portrait", Delay = 0,   Img = "https://images.unsplash.com/photo-1601121141499-bf26b69829a9?w=800&q=85" },
          new { Tag = "02 — Bespoke Leather",Name = "Đồ da Thủ công",     Slug = "tui-xach",   Cls = "coll-card--square",   Delay = 120, Img = "https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=800&q=85" },
          new { Tag = "03 — Luxury Watches", Name = "Đồng hồ Thời thượng",Slug = "dong-ho",   Cls = "coll-card--medium",   Delay = 240, Img = "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=800&q=85" }
        };
        foreach (var fc in fallbackCollections)
        {
          <a href="/product?category=@fc.Slug"
             class="coll-card @fc.Cls reveal-fade"
             style="--reveal-delay: @(fc.Delay)ms"
             aria-label="Xem @fc.Name">
            <img
              src="@fc.Img"
              alt="@fc.Name"
              class="coll-card__img"
              width="800" height="@(fc.Cls == "coll-card--portrait" ? 1067 : 800)"
              loading="@(fc.Delay == 0 ? "eager" : "lazy")" />
            <div class="coll-card__overlay" aria-hidden="true"></div>
            <div class="coll-card__body">
              <span class="coll-card__tag">@fc.Tag</span>
              <h3 class="coll-card__name">@fc.Name</h3>
              <span class="coll-card__link">
                Xem bộ sưu tập
                <i class="fa-solid fa-arrow-right fa-xs" aria-hidden="true"></i>
              </span>
            </div>
          </a>
        }
      }
    </div>
  </div>
</section>

@* ══════════════════════════════════════════════════════════════════════
   ACT 3 — BRAND STORY
   ══════════════════════════════════════════════════════════════════════ *@
<section class="story" id="story" aria-labelledby="story-title">
  <div class="story__img-wrap reveal-fade">
    <figure class="story__figure" style="position:relative;width:100%;height:100%">
      <img
        src="https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=900&q=85"
        alt="Xưởng thủ công Vietduy Atelier tại Florence"
        class="story__img"
        width="900" height="1125"
        loading="lazy" />
      <figcaption class="editorial-caption">Florence, Ý — 1987</figcaption>
    </figure>
  </div>

  <div class="story__content reveal-fade">
    <span class="story__eyebrow" aria-hidden="true">Notre Histoire</span>

    <blockquote class="story__quote">
      "Sự xa xỉ thực sự không phải là giá tiền,<br />
      mà là <em>sự tinh tế</em> không thể bắt chước."
    </blockquote>

    <p class="story__text">
      Được thành lập năm 1987 tại Paris, Maison Vietduy là biểu tượng
      của nghệ thuật thủ công Pháp. Mỗi sản phẩm là sự giao thoa giữa
      truyền thống lâu đời và thẩm mỹ đương đại — nơi bàn tay người thợ
      chạm vào linh hồn của vật&nbsp;liệu.
    </p>

    <a href="/contact" class="btn btn--ghost"><span>Tìm hiểu thêm</span></a>
  </div>

  <span class="story__since" aria-hidden="true">1987</span>
</section>

@* ══════════════════════════════════════════════════════════════════════
   ACT 3.5 — NUMBERS
   ══════════════════════════════════════════════════════════════════════ *@
<section class="numbers" aria-label="Thành tựu thương hiệu">
  <div class="container">
    <div class="numbers__grid">
      <div class="numbers__item reveal-up" style="--reveal-delay:0ms">
        <span class="numbers__val">38<em>+</em></span>
        <span class="numbers__label">Năm thủ công</span>
      </div>
      <div class="numbers__item reveal-up" style="--reveal-delay:100ms">
