        "Giao hàng toàn cầu", "Chất liệu thượng hạng", "Phục vụ 12.000+ khách hàng",
        "Thủ công tại Paris", "Chứng nhận GIA", "38 năm kinh nghiệm",
        "Giao hàng toàn cầu", "Chất liệu thượng hạng", "Phục vụ 12.000+ khách hàng"
      };
    }
