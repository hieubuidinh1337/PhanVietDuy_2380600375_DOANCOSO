@* _Pagination.cshtml — Generic pagination partial
   Model: X.PagedList.IPagedList or custom PageInfo *@
@model dynamic

@if (Model != null && Model.PageCount > 1)
{
  var current = (int)Model.PageNumber;
  var total   = (int)Model.PageCount;
  var query   = Context.Request.QueryString.Value ?? "";
  // Strip existing 'page' param
  var baseQuery = System.Text.RegularExpressions.Regex.Replace(query, @"[?&]page=\d+", "");
  var sep = baseQuery.Contains('?') ? "&" : "?";

  string PageUrl(int p) => $"{Context.Request.Path}{baseQuery}{sep}page={p}";

  <nav class="pagination" aria-label="Phân trang">
    @* Previous *@
    @if (current > 1)
    {
      <a href="@PageUrl(current - 1)" class="pagination__btn" aria-label="Trang trước">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </a>
    }
    else
    {
      <span class="pagination__btn pagination__btn--disabled" aria-disabled="true">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </span>
    }

    @* Pages *@
    @for (int p = 1; p <= total; p++)
    {
      if (p == 1 || p == total || (p >= current - 2 && p <= current + 2))
      {
        <a href="@PageUrl(p)"
           class="pagination__btn @(p == current ? "pagination__btn--active" : "")"
           aria-label="Trang @p"
           @(p == current ? "aria-current=page" : "")>
          @p
        </a>
      }
      else if (p == current - 3 || p == current + 3)
      {
        <span class="pagination__ellipsis" aria-hidden="true">…</span>
      }
    }

    @* Next *@
    @if (current < total)
    {
      <a href="@PageUrl(current + 1)" class="pagination__btn" aria-label="Trang tiếp theo">
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      </a>
    }
    else
    {
      <span class="pagination__btn pagination__btn--disabled" aria-disabled="true">
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      </span>
    }
  </nav>
}
