<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Vietduy Luxury Atelier</title>
  <meta name="robots" content="noindex" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />

  <style>
    /* ── Blank layout specific overrides ── */
    body {
      min-height: 100svh;
      overflow: auto;
    }

    .auth-layout {
      display: grid;
      grid-template-columns: 45fr 55fr;
      min-height: 100svh;
    }

    /* Left — brand panel */
    .auth-brand {
      background: var(--c-bg-dark);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 60px 56px;
      position: sticky;
      top: 0;
      height: 100svh;
      overflow: hidden;
    }

    .auth-brand::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=70') center/cover no-repeat;
      opacity: 0.12;
      pointer-events: none;
    }

    .auth-brand__logo {
      font-family: var(--ff-display);
      font-size: 1.8rem;
      font-weight: 400;
      letter-spacing: 0.22em;
      color: var(--c-bg);
      position: relative;
      z-index: 1;
    }

    .auth-brand__body {
      position: relative;
      z-index: 1;
    }

    .auth-brand__tagline {
      font-family: var(--ff-display);
      font-style: italic;
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      font-weight: 300;
      color: var(--c-gold-lt);
      line-height: 1.4;
      margin-bottom: var(--sp-6);
    }

    .auth-brand__quote {
      font-family: var(--ff-display);
      font-style: italic;
      font-size: 1.05rem;
      font-weight: 300;
      color: rgba(247,245,242,0.5);
      line-height: 1.65;
      max-width: 36ch;
    }

    .auth-brand__footer {
      position: relative;
      z-index: 1;
    }

    .auth-brand__since {
      font-size: var(--fs-2xs);
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(247,245,242,0.28);
    }

    /* Right — form panel */
    .auth-form-panel {
      background: var(--c-surface);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 60px;
      overflow-y: auto;
    }

    .auth-form-inner {
      width: 100%;
      max-width: 400px;
    }

    @@media (max-width: 768px) {
      .auth-layout { grid-template-columns: 1fr; }
      .auth-brand { display: none; }
      .auth-form-panel { padding: var(--sp-7) 24px; align-items: flex-start; }
    }
  </style>

  @RenderSection("Styles", required: false)
</head>
<body>
  <div class="auth-layout">
    @* Left: brand panel *@
    <aside class="auth-brand" role="complementary" aria-label="Vietduy Atelier">
      <a href="/" class="auth-brand__logo">Vietduy</a>
      <div class="auth-brand__body">
        <p class="auth-brand__tagline">L'art de vivre luxe<br/>depuis 1987</p>
        <blockquote class="auth-brand__quote">
          "Sự xa xỉ thực sự không phải là giá tiền,
          mà là sự tinh tế không thể bắt chước."
        </blockquote>
      </div>
      <div class="auth-brand__footer">
        <span class="auth-brand__since">Paris, 1987 — Present</span>
      </div>
    </aside>

    @* Right: form *@
    <main id="main-content" role="main" class="auth-form-panel">
      <div class="auth-form-inner">
        @RenderBody()
      </div>
    </main>
  </div>

  <div id="toastContainer" role="status" aria-live="polite"></div>
  <script type="module" src="~/js/app.js" asp-append-version="true"></script>
  @RenderSection("Scripts", required: false)
</body>
</html>
